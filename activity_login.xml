<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
     android:background="@color/white"
    tools:context="com.ohukaiv.uecaacmobile.Login">


    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:srcCompat="@drawable/uec_image_edited"
        android:contentDescription=""
        tools:ignore="ContentDescription"
        android:layout_below="@+id/toolBarLogin"
        android:layout_centerHorizontal="true" />

    <EditText
        android:id="@+id/editEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="13dp"
        android:ems="10"
        android:textSize="25sp"
        android:inputType="textEmailAddress"
        android:hint="@string/username"
        android:layout_below="@+id/imageView2"
        android:layout_alignLeft="@+id/editPassword"
        android:layout_alignStart="@+id/editPassword" />

    <EditText
        android:id="@+id/editPassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:ems="10"
        android:textSize="25sp"
        android:inputType="textPassword"
        android:hint="@string/password"
        android:layout_below="@+id/editEmail"
        android:layout_centerHorizontal="true" />

    <Button
        android:id="@+id/butlogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/editPassword"
        android:layout_centerHorizontal="true"
        android:textSize="25sp"
        android:textColor="@color/colorPrimary"
        android:textStyle="bold"
        android:layout_marginTop="25dp"
        android:background="@drawable/button_layout"
        android:text="@string/login" />

    <TextView
        android:id="@+id/textInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/butlogin"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="21dp"

        android:text="@string/textview" />

    <android.support.v7.widget.Toolbar
        android:id="@+id/toolBarLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:titleTextColor="@color/black"
        android:background="@color/colorPrimary"
        android:minHeight="?attr/actionBarSize"
        android:theme="?attr/actionBarTheme"
        app:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:titleMarginStart="50dp" />
    <ImageButton
        android:id="@+id/imageButtonLogBack"
        android:layout_width="50dp"
        android:layout_height="wrap_content"
        android:background="@drawable/button_bg"
        app:srcCompat="?attr/actionModeCloseDrawable"
        android:layout_alignParentTop="true"
        android:layout_alignBottom="@+id/toolBarLogin" />

</RelativeLayout>
